# =============================================================================
# Hostera24 — toate variabilele de mediu (copiază în .env la rădăcina proiectului)
# Backend, Next.js și Flutter citesc din acest fișier.
# =============================================================================

# --- Backend NestJS (port pe host) ---
PORT=3022
JWT_SECRET=schimba-aceasta-cheie-in-productie

# Parolă panou admin site (bcrypt hash; parola plain: 123456)
# Docker Compose: fiecare $ din hash → $$ (altfel hash gol → "Admin neconfigurat")
ADMIN_PASSWORD_HASH=$$2b$$10$$uDsp0Lxgb50/ix94qEvrFO7Og0gTlP0hWOo/5TBA78nx3GFD4bA.W

# --- MySQL (Docker Compose) — port pe host ---
MYSQL_PORT=3021
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=hostera24
MYSQL_USER=hostera24
MYSQL_PASSWORD=hostera24

# --- Conexiune backend → MySQL ---
# local (npm): localhost + MYSQL_PORT | în container api: mysql:3306 (setat în compose)
DATABASE_HOST=localhost
DATABASE_PORT=3021
DATABASE_NAME=hostera24
DATABASE_USER=hostera24
DATABASE_PASSWORD=hostera24
# Compensare citire scanat_la din MySQL (0 cu timezone: Z în TypeORM; 3 dacă orele sunt tot cu 3h în urmă)
# DB_SCANAT_OFFSET_HOURS=0

# --- Next.js (frontend-hostera24) — port pe host ---
FRONTEND_PORT=3023
# La VPS: după modificare rulează `docker compose build web` (valorile intră în JS la build)
NEXT_PUBLIC_API_URL=http://localhost:3022
# URL canonic al site-ului (SEO: sitemap, robots, Open Graph, link-uri canonice)
# Obligatoriu în producție: https://hostera24.com
# Pentru QR pe telefon: același IP ca WEB_BASE_URL (nu localhost)
NEXT_PUBLIC_SITE_URL=http://192.168.1.10:3023

# --- Flutter (app mobil) ---
API_BASE_URL=http://192.168.1.10:3022
WEB_BASE_URL=http://192.168.1.10:3023

# Telefon fizic / rețea locală — înlocuiește 192.168.1.10 cu IP-ul PC-ului (ipconfig):
# NEXT_PUBLIC_SITE_URL=http://192.168.1.10:3023
# API_BASE_URL=http://192.168.1.10:3022
# WEB_BASE_URL=http://192.168.1.10:3023

# Producție / Flutter → server VPS:
# NEXT_PUBLIC_API_URL=https://api.hostera24.com
# NEXT_PUBLIC_SITE_URL=https://hostera24.com
# API_BASE_URL=https://api.hostera24.com
# WEB_BASE_URL=https://hostera24.com

# --- Logo firmă (upload pe disk, servit la /uploads) ---
UPLOADS_DIR=uploads
# Trebuie același host ca API (Flutter API_BASE_URL / NEXT_PUBLIC_API_URL)
PUBLIC_UPLOADS_BASE_URL=http://192.168.1.10:3022/uploads
# producție VPS:
# API_BASE_URL=https://api.hostera24.com
# PUBLIC_UPLOADS_BASE_URL=https://api.hostera24.com/uploads

# --- Firebase / Google Sign-In (vezi docs/FIREBASE_GOOGLE_AUTH.md) ---
# Obligatoriu pe VPS: FIREBASE_PROJECT_ID + firebase-service-account.json la rădăcina proiectului
FIREBASE_PROJECT_ID=hostera24-f8585
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
# producție în .env:
# NEXT_PUBLIC_API_URL=https://api.hostera24.com
# NEXT_PUBLIC_SITE_URL=https://hostera24.com
# API_BASE_URL=https://api.hostera24.com
# WEB_BASE_URL=https://hostera24.com
# PUBLIC_UPLOADS_BASE_URL=https://api.hostera24.com/uploads
# Opțional pentru Flutter (deja în google-services.json / firebase_google_config.dart):
# FIREBASE_WEB_CLIENT_ID=757392952680-....apps.googleusercontent.com

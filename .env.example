# =============================================================================
# Hostera24 — toate variabilele de mediu (copiază în .env la rădăcina proiectului)
# Backend, Next.js și Flutter citesc din acest fișier.
# =============================================================================

# --- Backend NestJS ---
PORT=3000
JWT_SECRET=schimba-aceasta-cheie-in-productie

# --- MySQL (Docker Compose) ---
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=hostera24
MYSQL_USER=hostera24
MYSQL_PASSWORD=hostera24

# --- Conexiune backend → MySQL ---
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=hostera24
DATABASE_USER=hostera24
DATABASE_PASSWORD=hostera24

# --- Next.js (frontend-hostera24) ---
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# --- Flutter (app mobil) ---
API_BASE_URL=http://localhost:3000
WEB_BASE_URL=http://localhost:3001

# Telefon fizic / rețea locală (exemplu):
# API_BASE_URL=http://192.168.1.12:3000
# WEB_BASE_URL=http://192.168.1.12:3001

# Producție (exemplu):
# NEXT_PUBLIC_API_URL=https://api.hostera.com
# NEXT_PUBLIC_SITE_URL=https://hostera.com
# API_BASE_URL=https://api.hostera.com
# WEB_BASE_URL=https://hostera.com

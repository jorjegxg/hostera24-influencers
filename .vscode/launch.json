{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter (telefon / emulator)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}/hostera24",
      "toolArgs": [
        "--dart-define=API_BASE_URL=http://192.168.1.12:3000",
        "--dart-define=WEB_BASE_URL=http://192.168.1.12:3001"
      ]
    },
    {
      "name": "Flutter (Windows desktop)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}/hostera24",
      "deviceId": "windows",
      "toolArgs": [
        "--dart-define=API_BASE_URL=http://192.168.1.12:3000",
        "--dart-define=WEB_BASE_URL=http://192.168.1.12:3001"
      ]
    }
  ]
}

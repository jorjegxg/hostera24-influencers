{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter (server VPS — hostera24.com)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}/hostera24",
      "toolArgs": [
        "--dart-define=API_BASE_URL=https://api.hostera24.com",
        "--dart-define=WEB_BASE_URL=https://hostera24.com"
      ]
    },
    {
      "name": "Flutter (rețea locală)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}/hostera24",
      "toolArgs": [
        "--dart-define=API_BASE_URL=http://192.168.1.10:3022",
        "--dart-define=WEB_BASE_URL=http://192.168.1.10:3023"
      ]
    },
    {
      "name": "Flutter (Windows desktop — local)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}/hostera24",
      "deviceId": "windows",
      "toolArgs": [
        "--dart-define=API_BASE_URL=http://127.0.0.1:3022",
        "--dart-define=WEB_BASE_URL=http://127.0.0.1:3023"
      ]
    }
  ]
}
